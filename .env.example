PORT=3000
NEON_DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require
JWT_SECRET=replace-with-long-secret

# Comma-separated emails that register as auto-approved admins (optional).
ADMIN_EMAILS=adonis.arun@gmail.com

# First admin (recommended): put real values only in local .env (never commit passwords).
# Empty DB: npm run bootstrap-admin
# Existing users: BOOTSTRAP_FORCE=1 npm run bootstrap-admin
BOOTSTRAP_ADMIN_EMAIL=adonis.arun@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Adonis Arun

# Used in approval/rejection emails (optional). If unset, the server logs and skips send.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_PUBLIC_URL=http://localhost:3000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
